# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_32_characters_x
# Server-to-server URL (inside the compose network)
LIVEKIT_URL=ws://livekit:7880
# Browser-facing URL. Local: ws://localhost:7880. Production: wss://$LK_DOMAIN
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
# Local: 127.0.0.1 (default) so browsers on this machine reach the media ports;
# LAN testing: your machine's LAN IP. Production: leave EMPTY and set
# LIVEKIT_USE_EXTERNAL_IP=true instead.
#LIVEKIT_NODE_IP=127.0.0.1
#LIVEKIT_USE_EXTERNAL_IP=false

# --- Agent bridge ---
# Shared secret between web and agent-bridge control API
BRIDGE_TOKEN=change_me_bridge_token
BRIDGE_URL=http://agent-bridge:8090
# Speech-to-text / text-to-speech (required for voice agents)
OPENAI_API_KEY=
# Optional: ElevenLabs voices
ELEVENLABS_API_KEY=

# --- Demo agent (looped-af) ---
# Model provider key for the demo agent itself
ANTHROPIC_API_KEY=
# TTY trigger token the bridge uses to talk to the demo agent
SCOUT_TTY_TOKEN=change_me_scout_token

