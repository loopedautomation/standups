# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_32_characters_x
# Server-to-server URL (inside the compose network)
LIVEKIT_URL=ws://livekit:7880
# Browser-facing URL. Local: ws://localhost:7880. Production: wss://$LK_DOMAIN
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# Local: 127.0.0.1 (default) so browsers on this machine reach the media ports;
# LAN testing: your machine's LAN IP. Production: leave EMPTY and set
# LIVEKIT_USE_EXTERNAL_IP=true instead.
LIVEKIT_NODE_IP=127.0.0.1
#LIVEKIT_USE_EXTERNAL_IP=false
# Local dev on macOS/Windows Docker: keep true (UDP through the Docker proxy
# is flaky and causes 'negotiation' publish failures). Production: false.
LIVEKIT_FORCE_TCP=true

# --- Agent bridge ---
# Shared secret between web and agent-bridge control API
BRIDGE_TOKEN=change_me_bridge_token
BRIDGE_URL=http://agent-bridge:8090
# Speech-to-text / text-to-speech (required for voice agents)
OPENAI_API_KEY=
# Optional: ElevenLabs voices
ELEVENLABS_API_KEY=
# Barge-in: someone talking over a speaking agent cuts it off. On by default.
# Set to "off" if participants use open speakers and the agent keeps
# interrupting its own echo.
#AGENT_BARGE_IN=off
# Sustained speech (ms) that counts as an interruption rather than a cough.
#AGENT_BARGE_IN_MIN_SPEECH_MS=400
# Quiet window (ms) after the agent starts talking, before it can be cut off.
#AGENT_BARGE_IN_GRACE_MS=1000
# Screenshare vision: agents see a frame of whatever is being shared. On by
# default; "off" blinds them (they are told so, and say so if asked).
#AGENT_SCREEN_VISION=off

# --- Demo agent (looped-af) ---
# Model provider key for the demo agent itself
ANTHROPIC_API_KEY=
# TTY trigger token the bridge uses to talk to the demo agent
SCOUT_TTY_TOKEN=change_me_scout_token

# --- Infisical (production only) ---
# Machine-identity Universal Auth creds. When set, every container pulls its
# secrets from Infisical at start (docker-entrypoint.sh) and none of the
# secret values above need to exist on the host — only these two. Leave unset
# for local dev; the values above are used directly instead.
# Secret layout in Infisical (env: prod):
#   /shared            LIVEKIT_API_KEY, LIVEKIT_API_SECRET, BRIDGE_TOKEN,
#                      SCOUT_TTY_TOKEN
#   /apps/livekit      LIVEKIT_KEYS  ("<api-key>: <api-secret>")
#   /apps/agent-bridge OPENAI_API_KEY, ELEVENLABS_API_KEY
#   /apps/demo-agent   ANTHROPIC_API_KEY
#INFISICAL_CLIENT_ID=
#INFISICAL_CLIENT_SECRET=
# Defaults baked into docker-compose.yaml; override if they change:
#INFISICAL_PROJECT_ID=396f8208-593a-4966-8943-97621affc25a
#INFISICAL_API_URL=https://infisical.looped.sh/api
#INFISICAL_ENV=prod


# Gates meeting creation (unset = anyone can create; links always join freely)
MEET_MANAGEMENT_PASSWORD=change_me

# Optional short-link base for shared meeting links (e.g. https://lpd.sh/meet)
#SHARE_LINK_BASE=

# --- cal.com integration (optional; see calcom.md) ---
# Set CALCOM_WEBHOOK_SECRET to enable POST /api/integrations/cal as a cal.com
# webhook receiver: a new booking mints a meet room and the link is written
# back onto the booking. Must match the secret on the cal.com webhook.
#CALCOM_WEBHOOK_SECRET=
# A cal.com API key (Settings → Developer → API keys) owned by the event's
# host, used to set the meeting link on the booking. Without it the room link
# is still minted but can't be pushed back into cal.com.
#CALCOM_API_KEY=
# cal.com API base. Cloud (default): https://api.cal.com. Self-hosted: your
# API host, e.g. https://cal.example.com/api.
#CALCOM_API_BASE=https://api.cal.com

# Uncomment locally so plain `docker compose up` builds from source with
# the debug agent-registry.yaml mount (prod ignores this file):
#COMPOSE_FILE=docker-compose.yaml:docker-compose.build.yaml:docker-compose.debug.yaml
